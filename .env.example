# ===========================================
# Luigi Chat - Environment Variables Example
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# LITELLM PROXY CONFIGURATION
# ===========================================
# Master key for LiteLLM admin operations (must start with sk-)
LITELLM_MASTER_KEY=sk-your-master-key-here

# PostgreSQL database URL for LiteLLM
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://luigi:luigi_password@postgres:5432/litellm

# Redis URL for caching and sessions
# Format: redis://host:port
REDIS_URL=redis://redis:6379

# ===========================================
# MINIMAX API
# ===========================================
# Your MiniMax API key from https://platform.minimax.io
MINIMAX_API_KEY=your-minimax-api-key-here

# ===========================================
# BACKEND CONFIGURATION
# ===========================================
# JWT secret key for signing tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Application name
WEBUI_NAME=Luigi Chat

# LiteLLM proxy URL (for backend to call)
LITELLM_PROXY_URL=http://litellm:4000

# Backend server URL (for frontend)
BACKEND_URL=http://backend:8080

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# API URL for frontend (use localhost for dev, domain for prod)
PUBLIC_API_URL=http://localhost:8080

# Public backend URL (for production)
# PUBLIC_BACKEND_URL=https://api.yourdomain.com

# ===========================================
# DOCKER CONFIGURATION
# ===========================================
# PostgreSQL (for docker-compose)
POSTGRES_DB=luigi_chat
POSTGRES_USER=luigi
POSTGRES_PASSWORD=luigi_password

# ===========================================
# RATE LIMITING (Default per user)
# ===========================================
# Requests per minute
DEFAULT_RPM_LIMIT=3

# Tokens per minute
DEFAULT_TPM_LIMIT=6000

# Maximum budget per user (in USD)
DEFAULT_MAX_BUDGET=100

# ===========================================
# MODEL CONFIGURATION
# ===========================================
# These are the model aliases configured in LiteLLM
# luigi-thinking -> minimax/MiniMax-M2.7
# luigi-vision -> minimax/MiniMax-Text-01
# luigi-voice -> minimax/speech-2.6-hd

# Default model for new users
DEFAULT_MODEL=luigi-thinking

# ===========================================
# MINIMAX FILE API
# ===========================================
# Base URL for MiniMax API
MINIMAX_API_BASE_URL=https://api.minimax.io

# File upload purpose (fine-tune, batch, assistants)
FILE_UPLOAD_PURPOSE=fine-tune

# ===========================================
# MINIMAX SPEECH 2.6 TTS
# ===========================================
# Default voice ID
DEFAULT_VOICE_ID=male-qn-qingse

# Default speech speed (0.5 - 2.0)
DEFAULT_SPEECH_SPEED=1.0

# Default speech emotion (happy, sad, angry, neutral, fearful, disgusted, surprised)
DEFAULT_SPEECH_EMOTION=neutral

# TTS audio format (mp3, pcm, flac, wav)
TTS_FORMAT=mp3

# TTS sample rate (16000, 24000, 32000)
TTS_SAMPLE_RATE=32000

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# DEVELOPMENT
# ===========================================
# Set to true for development
DEBUG=true

# Reload backend on code changes
RELOAD=true
